#
#!/bin/bash

clear
echo
echo Langstone Sound Device Selection
echo --------------------------------
echo
SOUNDLIST="$(arecord -L | grep hw: | grep -v plughw:)"
if [ -z "$SOUNDLIST" ]
then
  echo No sound recording devices detected.
  echo No changes have been made  
else
echo These are the available sound recording devices:-
echo
PS3=$'\n'"Select the sound device to be used by Langstone: "
select DRIVER in $SOUNDLIST
do
 sed -i "s/audio\.source.*/audio\.source(48000, \"$DRIVER\", False)/" /home/pi/Langstone/Lang_TRX_Pluto.py
 sed -i "s/audio\.sink.*/audio\.sink(48000, \"$DRIVER\", False)/" /home/pi/Langstone/Lang_TRX_Pluto.py
 sed -i "s/audio\.source.*/audio\.source(48000, \"$DRIVER\", False)/" /home/pi/Langstone/Lang_TRX_Hack.py
 sed -i "s/audio\.sink.*/audio\.sink(48000, \"$DRIVER\", False)/" /home/pi/Langstone/Lang_TRX_Hack.py

 echo
 echo Langstone sound device changed to $DRIVER

 # ── Generate ALSA config files for NR (RNNoise) ──────────────────
 # Extract the card part only (e.g. hw:CARD=Device or hw:1)
 # LADSPA slave.pcm needs the hw: part without ,DEV=0
 HW_CARD=$(echo "$DRIVER" | sed 's/,DEV=.*//')

 # asound_flat.conf — direct to hardware, no NR
 cat > /home/pi/Langstone/asound_flat.conf << FLATEOF
# Langstone — direct audio (no noise reduction)
# Generated by set_sound on $(date)
# Device: $DRIVER

pcm.!default {
    type hw
    card ${HW_CARD#hw:CARD=}
}
ctl.!default {
    type hw
    card ${HW_CARD#hw:CARD=}
}
FLATEOF

 # asound_nr.conf — RNNoise LADSPA plugin in chain
 cat > /home/pi/Langstone/asound_nr.conf << NREOF
# Langstone — audio with RNNoise noise reduction (LADSPA)
# Generated by set_sound on $(date)
# Device: $DRIVER
# Requires: /usr/lib/ladspa/librnnoise_ladspa.so

pcm.rnnoiseout {
    type ladspa
    slave.pcm "$HW_CARD"
    path "/usr/lib/ladspa"
    plugins [{
        label noise_suppressor_mono
        input.controls [ 50 200 0 ]
    }]
}

pcm.!default {
    type plug
    slave.pcm "rnnoiseout"
}

ctl.!default {
    type hw
    card ${HW_CARD#hw:CARD=}
}
NREOF

 echo ALSA config files generated:
 echo "  /home/pi/Langstone/asound_flat.conf (direct)"
 echo "  /home/pi/Langstone/asound_nr.conf   (RNNoise NR)"

 # Apply flat config as default (NR off until selected in GUI)
 sudo cp /home/pi/Langstone/asound_flat.conf /etc/asound.conf
 echo Default ALSA config applied \(NR off\).

 break
done 
fi

echo
