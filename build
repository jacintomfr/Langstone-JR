#!/bin/bash
# Langstone V3H — Build Script
# Auto-increments LANGSTONE_VER_BUILD in version.h on each build

DIR="/home/pi/Langstone"
VER_FILE="$DIR/version.h"

# ── Auto-increment build number ──────────────────────────────────────────────
if [ -f "$VER_FILE" ]; then
    # Read current build number
    BUILD=$(grep 'LANGSTONE_VER_BUILD' "$VER_FILE" | grep -o '[0-9]*$')
    MAJOR=$(grep 'LANGSTONE_VER_MAJOR' "$VER_FILE" | grep -o '[0-9]*$')
    BUILD=$((BUILD + 1))
    # Format: Vxx-yyy (zero-padded)
    NEW_VER=$(printf "V%02d-%03d" $MAJOR $BUILD)
    # Update version.h
    sed -i "s/LANGSTONE_VER_BUILD  [0-9]*/LANGSTONE_VER_BUILD  $BUILD/" "$VER_FILE"
    sed -i "s/LANGSTONE_VERSION    \"V[0-9]*-[0-9]*\"/LANGSTONE_VERSION    \"$NEW_VER\"/" "$VER_FILE"
    echo "Building $NEW_VER"
else
    echo "Warning: version.h not found — building without version"
fi

# ── Compile ───────────────────────────────────────────────────────────────────
# Each line exits immediately on error so upgrade script gets correct exit code
cc $DIR/LangstoneGUI_Pluto.c -o $DIR/GUI_Pluto -liio -llgpio -lz -lm      || exit 1
cc $DIR/LangstoneGUI_Hack.c  -o $DIR/GUI_Hack  -llgpio -lz -lm -lpthread  || exit 1
cc $DIR/LangstoneGUI_Lime.c  -o $DIR/GUI_Lime  -llgpio 2>/dev/null || true
cc $DIR/HW_Test.c             -o $DIR/HW_Test   -llgpio                    || exit 1
cc $DIR/Pluto_Test.c          -o $DIR/Pluto_Test -liio                     || exit 1

# ── Report ────────────────────────────────────────────────────────────────────
if [ -f "$VER_FILE" ]; then
    VER=$(grep 'LANGSTONE_VERSION' "$VER_FILE" | grep -o '"V[^"]*"' | tr -d '"')
    echo "Build complete: $VER"
fi
